# --- M1 (KI-Listing) & M3 (Preisvorschläge): Anthropic ---
# API-Key für die KI-Listing-Generierung und Preisvorschläge.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Modell überschreiben (Default: claude-opus-4-8)
# Günstigere/schnellere Alternative: claude-sonnet-4-6
ANTHROPIC_MODEL=claude-opus-4-8

# --- M2 (Getragen-Look-Fotos): Replicate Virtual Try-On ---
# API-Token von https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_...

# Öffentlich erreichbares Foto einer Person/eines Modells, auf das das
# Kleidungsstück projiziert wird (IDM-VTON benötigt ein Personenbild).
TRYON_MODEL_IMAGE_URL=https://example.com/model.jpg

# Optional: Try-On-Modell überschreiben (Default: cuuupid/idm-vton)
# REPLICATE_TRYON_MODEL=cuuupid/idm-vton
