# --- Zugriffsschutz (optional, für Deployments) ---
# Wenn gesetzt, brauchen die KI-Routen (Listing/Preis/Deals/Getragen-Look)
# den Header "x-app-key" mit diesem Wert. Lokal leer lassen = offen.
# APP_API_KEY=ein-langes-zufälliges-geheimnis

# --- LLM-Anbieter für M1 (Listing), M3 (Preise), M5 (Deals) ---
# Wahl des Anbieters: "anthropic" (Default) oder "openrouter".
# Ohne explizite Angabe wird automatisch OpenRouter genutzt, wenn nur dessen
# Key gesetzt ist – sonst Anthropic.
# LLM_PROVIDER=anthropic

# Option A: Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
# Optional: Modell (Default claude-opus-4-8; günstiger: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-opus-4-8

# Option B: OpenRouter (OpenAI-kompatibel; auch günstige Modelle wie DeepSeek/Qwen/GLM)
# OPENROUTER_API_KEY=sk-or-...
# Modell-Slug. WICHTIG: M1 (Foto->Listing) braucht ein VISION-fähiges Modell,
# z. B. "qwen/qwen-2.5-vl-72b-instruct". Reine Textmodelle (z. B.
# "deepseek/deepseek-chat") funktionieren für M3/M5, aber NICHT für M1.
# OPENROUTER_MODEL=qwen/qwen-2.5-vl-72b-instruct

# --- M2 (Getragen-Look-Fotos): Replicate Image-Edit ---
# API-Token von https://replicate.com/account/api-tokens
# Erzeugt aus dem Flat-Lay direkt ein "getragen" aussehendes Bild – kein
# Modellfoto nötig.
REPLICATE_API_TOKEN=r8_...

# Optional: Bild-Modell überschreiben (Default: black-forest-labs/flux-kontext-pro)
# REPLICATE_WORNLOOK_MODEL=black-forest-labs/flux-kontext-pro
