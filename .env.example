# --- M1 (KI-Listing) & M3 (Preisvorschläge): Anthropic ---
# API-Key für die KI-Listing-Generierung und Preisvorschläge.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Modell überschreiben (Default: claude-opus-4-8)
# Günstigere/schnellere Alternative: claude-sonnet-4-6
ANTHROPIC_MODEL=claude-opus-4-8

# --- M2 (Getragen-Look-Fotos): Replicate Image-Edit ---
# API-Token von https://replicate.com/account/api-tokens
# Erzeugt aus dem Flat-Lay direkt ein "getragen" aussehendes Bild – kein
# Modellfoto nötig.
REPLICATE_API_TOKEN=r8_...

# Optional: Bild-Modell überschreiben (Default: black-forest-labs/flux-kontext-pro)
# REPLICATE_WORNLOOK_MODEL=black-forest-labs/flux-kontext-pro
